# ASF Mission Data - Local Development Configuration
# Copy to .env and source before running pipelines:
#   cp .env.example .env
#   source .env

# Data storage (local filesystem for development)
DATA_ROOT=/tmp/asf-pipeline-dev
HEARTBEAT_ROOT=/tmp/asf-pipeline-dev/heartbeats

# Environment identifier
ASF_ENVIRONMENT=dev

# Skip bronze stage when iterating on silver transformations
# Uncomment to enable:
# SKIP_BRONZE=1

# Slack webhook (optional — alerts print to console if not set)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/...
