# Python bytecode and compilation artifacts
# Generated every time Python imports a module. Always ignore.
__pycache__/
*.py[cod]
*$py.class

# Distribution and packaging
# Generated by build tools (pip install -e ., uv build, etc.)
build/
dist/
*.egg-info/
*.egg

# Virtual environments
.venv/

# Testing and coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Linting and formatting caches
.ruff_cache/
.mypy_cache/

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Environment and secrets
# NEVER commit these. Use .env.example to document what variables are needed.
.env
.env.local
.env.*.local

# Local data and pipeline output
# When running pipelines locally with DATA_ROOT=/tmp/pipeline-dev or similar,
# data files should never be committed. Parquet files can be large.
*.parquet
/data/

# Logs
*.log

# Cookie cutter
# TODO: (can remove once migration is fully complete)
.recipes/
.cookiecutter/state/

# Ignore infrastructure files that are generated by CDK synth or contain secrets
cdk.out/
